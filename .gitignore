# Credentials — never commit the real .env file
.env
*.env
!.env.example

# MCP config — contains live API tokens
.mcp.json

# Python
__pycache__/
*.py[cod]
.venv/
dist/

# macOS
.DS_Store

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/terraform.tfvars
infra/keys/

# Generated infra vars (written by setup_infra.sh) — commit .example files, not the real ones
ansible/vars/infra.yml
!ansible/vars/infra.yml.example
ansible/vars/network_creds.yml
!ansible/vars/network_creds.yml.example

# Slides — rendered PNGs are generated from .mmd source, no need to commit
slides/*.png
