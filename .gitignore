# Credentials — never commit the real .env file
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
dist/

# macOS
.DS_Store

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/terraform.tfvars
infra/keys/

# Generated infra vars (written by setup_infra.sh) — commit infra.yml.example not infra.yml
ansible/vars/infra.yml
!ansible/vars/infra.yml.example

# Slides — rendered PNGs are generated from .mmd source, no need to commit
slides/*.png

# Installed collections (downloaded via ansible-galaxy)
collections/ansible_collections/

# Temporary files
tmp/

# ansible-navigator artifacts
*-artifact-*.json
ansible-navigator.log

# Report backups
ansible/reports/*.html.*~
