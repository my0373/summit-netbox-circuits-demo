variable "aws_region" {
  description = "AWS region to deploy into"
  type        = string
  default     = "eu-west-3"  # Paris
}

variable "ssh_port" {
  description = "Non-standard SSH port (used on all VMs)"
  type        = number
  default     = 2222
}

variable "instance_type" {
  description = "EC2 instance type for the report server"
  type        = string
  default     = "t3.micro"
}

variable "key_name" {
  description = "AWS EC2 key pair name"
  type        = string
  default     = "summit-demo-2026"
}

variable "router_instance_type" {
  description = "EC2 instance type for the Cisco router (minimum c5n.large for IOS-XE)"
  type        = string
  default     = "c5n.large"
}

variable "router_password" {
  description = "Password for the local IOS user (iosuser) on the Cisco demo router — generated by setup_infra.sh"
  type        = string
  sensitive   = true
  # No default — must be supplied by setup_infra.sh so a fresh password is generated each provisioning run
}
