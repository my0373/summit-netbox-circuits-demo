---
# Generated by setup_infra.sh after running Terraform.
# Default values here mean "no infra configured" — plays that need these
# will skip gracefully until infra is provisioned.
report_server_host: ""
report_server_port: 2222
report_server_user: "ec2-user"
report_server_path: "/var/www/html/failover_report.html"
report_url: ""
router_ip: ""
router_password: ""   # generated by setup_infra.sh — never hardcode
infra_key_path: ""
