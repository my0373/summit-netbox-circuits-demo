# Generated by setup_infra.sh — do not commit (gitignored).
# In AAP: the Summit Demo Router credential injects ANSIBLE_NET_USERNAME and
#         ANSIBLE_NET_PASSWORD, picked up automatically by network_cli.
# Locally: these are used directly via add_host.
router_username: iosuser
router_password: ""   # set by setup_infra.sh

# Gateway IPs are no longer stored here — they are sourced at runtime from the
# 'gateway_ip' custom field on circuit terminations in NetBox. Set this field on
# the A-end termination of each circuit that has a real router attached.
