# NetBox Cloud
NETBOX_URL=https://your-instance.netboxcloud.com
NETBOX_TOKEN=your_netbox_api_token_here

# Ansible Automation Platform
AAP_URL=https://your-aap-instance.example.com
AAP_USERNAME=your_aap_username
AAP_PASSWORD=your_aap_password
# Alternatively, use a token instead of username/password:
# AAP_TOKEN=your_aap_oauth_token
