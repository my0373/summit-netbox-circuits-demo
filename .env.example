# NetBox Cloud
NETBOX_URL=https://your-instance.netboxcloud.com
NETBOX_TOKEN=your_netbox_api_token_here

# Ansible Automation Platform
AAP_URL=https://your-aap-instance.example.com
AAP_USERNAME=your_aap_username
AAP_PASSWORD=your_aap_password
# AAP Controller API token — used by the NetBox webhook to trigger the workflow.
# Generate via: AAP UI → Access → Users → Tokens.
AAP_TOKEN=your_aap_controller_token_here

# EDA event stream shared token (any strong random string — must match what is
# configured in EDA and sent by the NetBox webhook)
EDA_STREAM_TOKEN=your_eda_stream_token_here

# Container Registry (for pulling EE images from quay.io / registry.redhat.io)
REGISTRY_HOST=quay.io
REGISTRY_USERNAME=your_registry_username
REGISTRY_PASSWORD=your_registry_password

# Automation Hub (for syncing certified collections)
AH_URL=https://console.redhat.com/api/automation-hub/
AH_TOKEN=your_automation_hub_token_here

# Infrastructure (optional — populated by setup_infra.sh after Terraform)
# Leave empty to skip report publishing and router registration.
REPORT_SERVER_HOST=
REPORT_SERVER_PORT=2222
REPORT_URL=
ROUTER_IP=
ROUTER_PASSWORD=
ROUTER_USERNAME=iosuser
ROUTER_PRIMARY_GW=172.16.0.1
ROUTER_BACKUP_GW=172.16.1.1
PRIVATE_KEY_PATH=
